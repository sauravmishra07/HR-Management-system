# ===== Server =====
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1
CLIENT_URL=http://localhost:5173

# ===== Database =====
MONGODB_URI=mongodb+srv://chandila879_db_user:yycaML43GPIlRWp6@hrms0.eq5p1we.mongodb.net/ramp_hrms?retryWrites=true&w=majority&appName=hrms0

# ===== JWT =====
JWT_ACCESS_SECRET=change_this_access_secret_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_refresh_secret_in_production
JWT_REFRESH_EXPIRES_IN=7d
JWT_RESET_SECRET=change_this_reset_secret_in_production
JWT_RESET_EXPIRES_IN=15m

# ===== Security =====
BCRYPT_SALT_ROUNDS=10
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20
COOKIE_SECRET=change_this_cookie_secret

# ===== Mail (Nodemailer) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="RAMP HRMS <hr@itsybizz.com>"

# ===== Uploads =====
UPLOAD_DIR=src/uploads
MAX_FILE_SIZE_MB=10

# ===== Cloudinary (file storage) =====
# Get these from https://console.cloudinary.com  (Dashboard -> Product Environment Credentials).
# Document uploads require all three to be set.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=ramp-hrms

# ===== Seed default admin password =====
SEED_DEFAULT_PASSWORD=Password@123

# ===== DDD (ITSYBIZZ Command Center) integration =====
# Shared secret for server-to-server calls — must match INTEGRATION_API_KEY in the DDD server .env.
INTEGRATION_API_KEY=
DDD_API_URL=http://localhost:5500/api/v1
INTEGRATION_ENABLED=true
